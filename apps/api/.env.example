APP_NAME=DOST Phil Onion Watch API
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALGORITHM=HS256
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=phil_onion_watch
POSTGRES_USER=onion
POSTGRES_PASSWORD=onion
DATABASE_URL=postgresql+psycopg://onion:onion@postgres:5432/phil_onion_watch
REDIS_URL=redis://redis:6379/0
FAISS_INDEX_PATH=/workspace/apps/api/storage/faiss/knowledge.index
FAISS_METADATA_PATH=/workspace/apps/api/storage/faiss/knowledge_meta.json
REPORTS_PATH=/workspace/data/fixtures/reports
LOCAL_EMBEDDING_DIM=128
SCHEDULER_TIMEZONE=Asia/Manila
MONTHLY_PIPELINE_CRON=0 2 1 * *
ALERT_REFRESH_CRON=0 6 * * *
REPORT_GENERATION_CRON=30 2 1 * *
REINDEX_DOCUMENTS_CRON=45 2 1 * *
JOB_MAX_RETRIES=3
JOB_RETRY_BACKOFF_SECONDS=15
NOTIFICATION_WEBHOOK_URL=
