APP_NAME=DOST Phil Onion Watch API
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALGORITHM=HS256
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=phil_onion_watch
POSTGRES_USER=onion
POSTGRES_PASSWORD=onion
DATABASE_URL=postgresql+psycopg://onion:onion@postgres:5432/phil_onion_watch
REDIS_URL=redis://redis:6379/0
OIDC_ENABLED=false
OIDC_DISCOVERY_URL=
OIDC_ISSUER_URL=
OIDC_JWKS_URL=
OIDC_AUDIENCE=
OIDC_SIGNING_ALGORITHMS=RS256,HS256
OIDC_ROLE_CLAIM=roles
OIDC_ROLE_MAPPING=
OIDC_EMAIL_CLAIM=email
OIDC_NAME_CLAIM=name
OIDC_SUBJECT_CLAIM=sub
OIDC_MFA_CLAIM=amr
OIDC_MFA_BOOLEAN_CLAIM=mfa
OIDC_MFA_METHODS=mfa,otp,webauthn,sms,hwk
OIDC_MFA_ACR_CLAIM=acr
OIDC_MFA_ACR_VALUES=mfa,urn:mfa
OIDC_PRIVILEGED_ROLES=super_admin,provincial_admin
OIDC_SYNC_ROLES_ON_LOGIN=true
OIDC_AUTO_PROVISION_USERS=false
OIDC_CACHE_TTL_SECONDS=300
ENFORCE_OIDC_FOR_PRIVILEGED_ROLES=false
ENFORCE_MFA_FOR_PRIVILEGED_TOKENS=false
FAISS_INDEX_PATH=/workspace/apps/api/storage/faiss/knowledge.index
FAISS_METADATA_PATH=/workspace/apps/api/storage/faiss/knowledge_meta.json
REPORTS_PATH=/workspace/data/fixtures/reports
LOCAL_EMBEDDING_DIM=128
SCHEDULER_TIMEZONE=Asia/Manila
MONTHLY_PIPELINE_CRON=0 2 1 * *
ALERT_REFRESH_CRON=0 6 * * *
REPORT_GENERATION_CRON=30 2 1 * *
REPORT_DISTRIBUTION_CRON=0 */6 * * *
OBSERVABILITY_MONITOR_CRON=*/5 * * * *
REINDEX_DOCUMENTS_CRON=45 2 1 * *
DOCUMENT_INGESTION_CRON=*/2 * * * *
AGENCY_FEED_INGESTION_CRON=15 */6 * * *
GEOSPATIAL_ENABLE_POSTGIS=true
GEOSPATIAL_DEFAULT_SRID=4326
GEOSPATIAL_STAC_SENTINEL2_ENABLED=true
GEOSPATIAL_STAC_SENTINEL1_ENABLED=true
GEOSPATIAL_STAC_LANDSAT_ENABLED=true
JOB_MAX_RETRIES=3
JOB_RETRY_BACKOFF_SECONDS=15
REPORT_DISTRIBUTION_BATCH_SIZE=50
REPORT_DISTRIBUTION_DEFAULT_MAX_ATTEMPTS=3
REPORT_DISTRIBUTION_RETRY_BACKOFF_SECONDS=300
OBSERVABILITY_WINDOW_MINUTES=60
OBSERVABILITY_EVENT_RETENTION_MINUTES=1440
OBSERVABILITY_ALERT_COOLDOWN_SECONDS=900
DEGRADED_ENDPOINT_MIN_REQUESTS=20
DEGRADED_ENDPOINT_ERROR_RATE_THRESHOLD=0.2
DEGRADED_ENDPOINT_P95_LATENCY_MS_THRESHOLD=1500
JOB_FAILURE_MIN_RUNS=3
JOB_FAILURE_RATE_THRESHOLD=0.3
DOCUMENT_INGESTION_JOB_MAX_ATTEMPTS=5
DOCUMENT_CHUNK_MAX_RETRIES=3
DOCUMENT_INGESTION_BATCH_SIZE=4
AGENCY_FEED_FIXTURES_PATH=/workspace/data/fixtures/feeds
REPORT_DISTRIBUTION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_URL=
